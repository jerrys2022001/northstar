3.38615 2.9623 3.62838C2.72007 3.87061 2.58398 4.19915 2.58398 4.54172V17.4583C2.58398 17.8009 2.72007 18.1294 2.9623 18.3716C3.20453 18.6139 3.53307 18.7499 3.87564 18.7499H12.6508C12.8204 18.7501 12.9883 18.7166 13.1449 18.6515C13.3015 18.5864 13.4436 18.4909 13.5631 18.3705L17.7044 14.2291C17.8248 14.1097 17.9203 13.9676 17.9854 13.811C18.0506 13.6544 18.084 13.4865 18.0839 13.3169V4.54172C18.0839 4.19915 17.9478 3.87061 17.7055 3.62838C17.4633 3.38615 17.1348 3.25006 16.7922 3.25006ZM12.9172 17.1919V13.5833H16.5258L12.9172 17.1919Z" fill="#32517D"/></g></svg></a></div></div></div><div class="w-full mt-[86px] flex flex-col justify-start items-center"><h2 class="text-[#32517D] text-[24px] md:text-[28px] lg:text-[30px] xl:text-[32px] font-semibold leading-none tracking-tighter" style="font-feature-settings:&#x27;clig&#x27; off, &#x27;liga&#x27; off">Dynamic voices for all your needs</h2><p class="mt-[24px] text-center max-w-[642px] max-md:text-left" style="color:#5E5E5E;font-feature-settings:&#x27;clig&#x27; off, &#x27;liga&#x27; off;font-size:16px;font-style:normal;font-weight:400;line-height:normal">Listnr offers a wide range of multi-lingual voices that are perfect for all your content needs. From podcasts to video ads, we&#x27;ve got you covered.</p><div class="w-full mt-[56px] flex flex-col justify-start items-center"><div class="w-full grid grid-flow-row max-md:grid-cols-1 grid-cols-3 gap-x-[20px] gap-y-[20px] max-w-[800px] mx-auto"><div class="relative w-full h-[400px] font-inter shadow-lg rounded-xl overflow-hidden flex flex-col justify-end items-start group cursor-pointer" style="background-image:linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url(https://image.lexica.art/full_webp/66c1aeea-70ed-4201-8221-3173216ae1a7);background-size:cover;background-position:center;background-repeat:no-repeat"><div class="absolute top-4 right-4 z-10"><div class="p-3 cursor-pointer rounded-full bg-white/20 backdrop-blur-sm flex flex-col justify-center items-center hover:bg-white/30 transition-all"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 384 512" color="white" style="color:white" height="16" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M73 39c-14.8-9.1-33.4-9.4-48.5-.9S0 62.6 0 80V432c0 17.4 9.4 33.4 24.5 41.9s33.7 8.1 48.5-.9L361 297c14.3-8.7 23-24.2 23-41s-8.7-32.2-23-41L73 39z"/></svg></div></div><div class="w-full p-6 text-white"><h3 class="text-lg font-bold leading-tight">Sexy Female Villain Voice</h3><div class="mt-2 flex gap-2"><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">English</span><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">Female</span></div></div></div><div class="relative w-full h-[400px] font-inter shadow-lg rounded-xl overflow-hidden flex flex-col justify-end items-start group cursor-pointer" style="background-image:linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url(https://image.lexica.art/full_webp/10cd1ca3-2e72-4bf8-a4d3-ed9d2ab63303);background-size:cover;background-position:center;background-repeat:no-repeat"><div class="absolute top-4 right-4 z-10"><div class="p-3 cursor-pointer rounded-full bg-white/20 backdrop-blur-sm flex flex-col justify-center items-center hover:bg-white/30 transition-all"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 384 512" color="white" style="color:white" height="16" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M73 39c-14.8-9.1-33.4-9.4-48.5-.9S0 62.6 0 80V432c0 17.4 9.4 33.4 24.5 41.9s33.7 8.1 48.5-.9L361 297c14.3-8.7 23-24.2 23-41s-8.7-32.2-23-41L73 39z"/></svg></div></div><div class="w-full p-6 text-white"><h3 class="text-lg font-bold leading-tight">Carter the Mountain King</h3><div class="mt-2 flex gap-2"><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">English</span><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">Male</span></div></div></div><div class="relative w-full h-[400px] font-inter shadow-lg rounded-xl overflow-hidden flex flex-col justify-end items-start group cursor-pointer" style="background-image:linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url(https://image.lexica.art/full_webp/053ba445-ef64-4036-8a07-5b2417e5e24a);background-size:cover;background-position:center;background-repeat:no-repeat"><div class="absolute top-4 right-4 z-10"><div class="p-3 cursor-pointer rounded-full bg-white/20 backdrop-blur-sm flex flex-col justify-center items-center hover:bg-white/30 transition-all"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 384 512" color="white" style="color:white" height="16" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M73 39c-14.8-9.1-33.4-9.4-48.5-.9S0 62.6 0 80V432c0 17.4 9.4 33.4 24.5 41.9s33.7 8.1 48.5-.9L361 297c14.3-8.7 23-24.2 23-41s-8.7-32.2-23-41L73 39z"/></svg></div></div><div class="w-full p-6 text-white"><h3 class="text-lg font-bold leading-tight">David - Epic Movie Trailer</h3><div class="mt-2 flex gap-2"><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">English</span><span class="px-2 py-1 bg-white/20 backdrop-blur-sm rounded-md text-xs font-medium">Male</span></div></div></div></div></div><div class="w-full flex max-md:flex-col-reverse flex-row justify-center items-center mt-[46px] gap-x-[30px] gap-y-[30px]"><a target="_blank" rel="noopener noreferrer" class="flex flex-col justify-center items-center px-6 py-3 rounded-lg bg-[#27476A] text-white font-medium hover:bg-[#1e3a52] transition-colors" href="https://voices.listnr.ai/login">Test these voices out in our editor →</a></div></div><div class="w-full mt-[80px] md:mt-[120px] flex flex-col justify-start items-center"><div class="w-full max-w-[1200px] mx-auto px-4"><h2 class="text-[#000000] text-center text-[24px] md:text-[32px] lg:text-[36px] xl:text-[40px] font-semibold leading-tight tracking-tight mb-6" style="font-feature-settings:&#x27;clig&#x27; off, &#x27;liga&#x27; off">Powerful and Feature-Rich,<br>Online Text-to-Voice Studio</h2><p class="text-[#5E5E5E] text-center text-[16px] md:text-[18px] lg:text-[20px] opacity-90 max-w-[800px] mx-auto mb-12 px-4">Type, paste or import text and instantly turn it into audio with our online <a class="text-blue-600 hover:text-blue-800 underline" href="https://listnr.ai/text-to-speech">Text to Speech</a> editor. Enhance the audio with speech styles, pronunciations and SSML tags.</p><div class="w-full flex justify-center"><img alt="TTS Editor Interface" loading="lazy" width="800" height="480" decoding="async" data-nimg="1" class="rounded-xl shadow-2xl max-w-full h-auto" style="color:transparent" sizes="(max-width: 768px) 100vw, 800px" srcset="/_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=3840&amp;q=75 3840w" src="/_next/image?url=https%3A%2F%2Fpub-ccb1ce1d251a463e88b81cef7639e95d.r2.dev%2FTTSEditor-66.avif&amp;w=3840&amp;q=75"></div></div></div><div class="w-full mt-[40px] md:mt-[60px] py-12 md:py-16"><div class="w-full max-w-[1200px] mx-auto px-4"><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12"><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">1000+ voices</h5><p class="relative z-10 text-gray-600 leading-relaxed">Choose from a growing library of 1000+ natural-sounding Text to Speech voices across 142+ languages and accents.</p></div><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-green-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">Speech Styles</h5><p class="relative z-10 text-gray-600 leading-relaxed">Use expressive emotional speaking styles to make the voices sound more natural and engaging.</p></div><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M16 7c0 2.21-1.79 4-4 4s-4-1.79-4-4 1.79-4 4-4 4 1.79 4 4zM12 14.5c-2.67 0-8 1.34-8 4v2.5h16V18.5c0-2.66-5.33-4-8-4z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">Multi-Voice Feature</h5><p class="relative z-10 text-gray-600 leading-relaxed">Create conversations in your audio projects by using different voices in the same audio file.</p></div><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-yellow-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12.45 16h2.09L9.43 3H7.57L2.46 16h2.09l1.12-3h5.64l1.14 3zm-6.02-5L8.5 5.48 10.57 11H6.43zm15.16.59l-8.09 8.09L9.83 16l-1.41 1.41 5.09 5.09L23 13l-1.41-1.41z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">Custom Pronunciations</h5><p class="relative z-10 text-gray-600 leading-relaxed">Define how specific words are pronounced. Save and re-use those pronunciations when synthesizing speech.</p></div><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-orange-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">Voice Inflections</h5><p class="relative z-10 text-gray-600 leading-relaxed">Fine-tune the rate, pitch, emphasis and add pauses to create a more suitable voice tone.</p></div><div class="flex flex-col items-start p-6 border border-gray-100 rounded-xl bg-white hover:bg-gray-50/80 transition-colors relative overflow-hidden"><div class="absolute inset-0 bg-[url(&#x27;/noise.svg&#x27;)] opacity-30"></div><div class="absolute inset-0 bg-gradient-to-br from-pink-50/50 to-transparent"></div><div class="relative z-10 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div><h5 class="relative z-10 text-xl md:text-2xl font-semibold mb-3 text-gray-900">Preview Mode</h5><p class="relative z-10 text-gray-600 leading-relaxed">Listen and preview a single paragraph or full text before converting it to speech.</p></div></div></div></div><div class="w-full mt-[60px] md:mt-[80px] py-16 md:py-24"><div class="w-full max-w-[1200px] mx-auto px-4 text-center"><h2 class="text-[32px] md:text-[40px] lg:text-[48px] font-bold leading-tight mb-6 text-[#000000]">Try our free AI voice generator<br>text to speech studio</h2><p class="text-[#5E5E5E] text-[16px] md:text-[18px] lg:text-[20px] max-w-[800px] mx-auto mb-16">Create engaging voice content for audiobooks, YouTube videos, or documentaries, with unique AI voices from the best AI voice over generator.</p><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12"><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">AI voice over for videos</h3><p class="text-gray-600 leading-relaxed">Power your videos with clear, consistent, and professional voiceovers. Perfect for marketing, explainer, product demos, and YouTube videos.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Narration</h3><p class="text-gray-600 leading-relaxed">Narrate your audiobooks with ultra-realistic voices seamlessly and effectively. Shorten your production time by generating audio in seconds.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M21.99 4c0-1.1-.89-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.89 2 2 2h14l4 4-.01-18z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Conversational AI</h3><p class="text-gray-600 leading-relaxed">Voice your conversational assistants, receptionists, and telemarketing solutions with ultra-realistic, humanlike voices. Create scalable, delightful customer experiences.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2ZM21 9V7L15 1L13.5 2.5L3.91 12.09C3.66 12.34 3.66 12.76 3.91 13.01L10.99 20.09C11.24 20.34 11.66 20.34 11.91 20.09L21.41 10.59C21.75 10.25 21.75 9.65 21.41 9.31L21 9Z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Custom voices</h3><p class="text-gray-600 leading-relaxed">Modify your existing voiceovers, or generate a unique custom voice that perfectly fits your brand and target audience.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">eLearning</h3><p class="text-gray-600 leading-relaxed">Curate engaging e-learning material with voices capable of pronouncing terminologies and technical jargon like actual subject matter experts.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Podcasts</h3><p class="text-gray-600 leading-relaxed">Create engaging, multi speaker, conversational podcasts with the industry&#x27;s first dialog-enabled podcast creation studio.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M15 7.5V2H9v5.5l3 3 3-3zM7.5 9H2v6h5.5l3-3-3-3zM9 16.5V22h6v-5.5l-3-3-3 3zM16.5 9l-3 3 3 3H22V9h-5.5z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Gaming</h3><p class="text-gray-600 leading-relaxed">Streamline your game&#x27;s pre-production with ultra-realistic AI voices. The perfect placeholder for voice acting for your Pre-Vis and Pitch-Vis needs.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">IVR systems</h3><p class="text-gray-600 leading-relaxed">Automate your IVR system&#x27;s voice responses with AI voices. Revolutionize your customer experience by delivering seamless, personalized interactions every time.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M9 9m-4 0a4 4 0 1 1 8 0a4 4 0 1 1 -8 0"/><path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 6.27a8 8 0 0 1 0 11.46"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Dubbing</h3><p class="text-gray-600 leading-relaxed">Localize your video and voice content in seconds. Automatically dub your existing audio into other languages. Instantly make your videos accessible to a global audience.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 7h-6v13h-2v-6h-2v6H9V9H3V7h18v2z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Accessibility</h3><p class="text-gray-600 leading-relaxed">Integrate human-like voices in your assistive voice devices and applications. Provide ultra-realistic voice experiences to enhance accessibility.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">API</h3><p class="text-gray-600 leading-relaxed">Make use of Listnr&#x27;s Voice Generation API to power your conversational chatbot, live streams, and games. Reduce development time and costs.</p></div><div class="flex flex-col items-start text-left"><div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#6366F1]" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12l-4.463 4.969-4.537-4.969h3c0-4.97 4.03-9 9-9 2.395 0 4.565.942 6.179 2.468l-2.004 2.231c-1.081-1.05-2.553-1.699-4.175-1.699-3.309 0-6 2.691-6 6h3zm10.463-4.969l-4.463 4.969h3c0 3.309-2.691 6-6 6-1.623 0-3.094-.65-4.175-1.699l-2.004 2.231c1.613 1.526 3.784 2.468 6.179 2.468 4.97 0 9-4.03 9-9h3l-4.537-4.969z"/></svg></div><h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-900">Commercial rights</h3><p class="text-gray-600 leading-relaxed">Use AI-generated voices commercially with full rights. Perfect for monetized content, advertising, and commercial projects without licensing restrictions.</p></div></div></div></div></div></div><div class="jsx-eb5b0fd6f3796857 relative z-[20]"><div class="mt-[160px] md:mt-[176px] font-sans w-full flex flex-col gap-y-8 md:flex-row justify-center items-center gap-x-[32px] px-[24px] md:px-[50px] lg:px-[80px] xl:px-[112px] relative z-[100]"><div class="flex flex-col justify-start items-center gap-y-4"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M9.50635 34.6687C11.1529 31.3537 12.0066 27.7014 12.0001 24C12.0017 22.2003 12.4067 20.4239 13.1855 18.8015C13.9643 17.1791 15.0969 15.7519 16.5001 14.625" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 24C24.0081 30.1007 22.4593 36.1026 19.5 41.4375" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 24C18 22.4087 18.6321 20.8826 19.7574 19.7574C20.8826 18.6321 22.4087 18 24 18C25.5913 18 27.1174 18.6321 28.2426 19.7574C29.3679 20.8826 30 22.4087 30 24C30.0124 30.185 28.6482 36.2952 26.0062 41.8875" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M40.9875 34.5C41.6592 31.0403 41.9982 27.5243 42 24C42 19.2261 40.1036 14.6477 36.7279 11.2721C33.3523 7.89642 28.7739 6 24 6C19.2261 6 14.6477 7.89642 11.2721 11.2721C7.89642 14.6477 6 19.2261 6 24C6.00537 26.0445 5.65646 28.0746 4.96875 30" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M17.4001 30C16.7524 33.1548 15.6069 36.1865 14.0063 38.9812" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.5 12.0938C22.9978 12.0339 23.4986 12.0026 24 12C27.1826 12 30.2348 13.2643 32.4853 15.5147C34.7357 17.7652 36 20.8174 36 24C35.9983 26.0058 35.873 28.0096 35.625 30" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M34.4812 36C34.1999 37.1063 33.8812 38.2125 33.5249 39.2812" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg><h2 class="text-center font-medium text-[#32517D]" style="font-size:20px;line-height:28px;letter-spacing:-0.34px">Natural, Human-Like AI Voices</h2><p class="text-[#353C4499]/60 text-center font-normal max-w-[384px]" style="font-size:16px;line-height:22px;letter-spacing:-0.208px">Listnr provides access to over 1000 lifelike voices, crafted to sound natural and engaging, across 142+ languages. Bring authenticity and a human touch to your voiceovers, making your content more relatable and impactful.</p></div><div class="flex flex-col justify-start items-center gap-y-4"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M39.75 18.75C41.8211 18.75 43.5 17.0711 43.5 15C43.5 12.9289 41.8211 11.25 39.75 11.25C37.6789 11.25 36 12.9289 36 15C36 17.0711 37.6789 18.75 39.75 18.75Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.5 27.5625V9C16.5 7.4087 17.1321 5.88258 18.2574 4.75736C19.3826 3.63214 20.9087 3 22.5 3C24.0913 3 25.6174 3.63214 26.7426 4.75736C27.8679 5.88258 28.5 7.4087 28.5 9V27.5625C30.1003 28.8119 31.2706 30.5296 31.8478 32.4761C32.4249 34.4226 32.38 36.5006 31.7194 38.4204C31.0587 40.3401 29.8153 42.0057 28.1626 43.1848C26.5098 44.3639 24.5302 44.9977 22.5 44.9977C20.4698 44.9977 18.4902 44.3639 16.8374 43.1848C15.1847 42.0057 13.9413 40.3401 13.2806 38.4204C12.62 36.5006 12.5751 34.4226 13.1522 32.4761C13.7294 30.5296 14.8997 28.8119 16.5 27.5625V27.5625Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.5 39C24.5711 39 26.25 37.3211 26.25 35.25C26.25 33.1789 24.5711 31.5 22.5 31.5C20.4289 31.5 18.75 33.1789 18.75 35.25C18.75 37.3211 20.4289 39 22.5 39Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.5 31.5V16.5" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg><h2 class="text-center font-medium text-[#32517D]" style="font-size:20px;line-height:28px;letter-spacing:-0.34px">AI Voice Emotion Fine-Tuning</h2><p class="text-[#353C4499]/60 text-center font-normal max-w-[384px]" style="font-size:16px;line-height:22px;letter-spacing:-0.208px">Add depth to your voiceovers with Listnr’s Emotion Fine-Tuning feature. Adjust tones to convey specific emotions, from excitement to calm, creating a powerful connection with your audience in over 142 languages.</p></div><div class="flex flex-col justify-start items-center gap-y-4"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M24 20.25V40.5" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 7.5V12.75" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 20.25C26.0711 20.25 27.75 18.5711 27.75 16.5C27.75 14.4289 26.0711 12.75 24 12.75C21.9289 12.75 20.25 14.4289 20.25 16.5C20.25 18.5711 21.9289 20.25 24 20.25Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M37.5 35.25V40.5" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M37.5 7.5V27.75" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M37.5 35.25C39.5711 35.25 41.25 33.5711 41.25 31.5C41.25 29.4289 39.5711 27.75 37.5 27.75C35.4289 27.75 33.75 29.4289 33.75 31.5C33.75 33.5711 35.4289 35.25 37.5 35.25Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.5 29.25V40.5" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.5 7.5V21.75" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.5 29.25C12.5711 29.25 14.25 27.5711 14.25 25.5C14.25 23.4289 12.5711 21.75 10.5 21.75C8.42893 21.75 6.75 23.4289 6.75 25.5C6.75 27.5711 8.42893 29.25 10.5 29.25Z" stroke="#32517D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg><h2 class="text-center font-medium text-[#32517D]" style="font-size:20px;line-height:28px;letter-spacing:-0.34px">Precision Voice Control</h2><p class="text-[#353C4499]/60 text-center font-normal max-w-[384px]" style="font-size:16px;line-height:22px;letter-spacing:-0.208px">Gain precise control over the flow and rhythm of your content with Listnr’s punctuation and pause customization. Enhance clarity and pacing in your voiceovers, ensuring a smooth, natural listening experience across 1000+ voices in 142+ languages.</p></div></div></div></div><div class="jsx-eb5b0fd6f3796857 w-full max-w-[1510px] mx-auto"><div class="jsx-eb5b0fd6f3796857 relative z-[20]"><div class="mt-[160px] md:mt-[176px] font-sans w-full flex flex-col justify-start items-center max-lg:px-[24px]"><h2 class="max-md:w-[80%] max-md:self-start" style="color:#353C44;font-feature-settings:&#x27;clig&#x27; off, &#x27;liga&#x27; off;font-size:36px;font-style:normal;font-weight:600;line-height:100%;letter-spacing:-1.44px">1000+ AI Voices in 142+ Languages</h2><p class="mt-[24px] text-center max-w-[542px] max-md:text-left" style="color:#5E5E5E;font-feature-settings:&#x27;clig&#x27; off, &#x27;liga&#x27; off;font-size:16px;font-style:normal;font-weight:400;line-height:normal">Listnr&#x27;s SOTA generative AI makes voiceovers feel extremely natural. Your viewers won&#x27;t realise it&#x27;s not a human.</p><div class="lg:px-[56px] xl:px-[124px] flex flex-row justify-center items-center flex-wrap gap-2 mt-[66px] max-md:w-full"><div class="max-md:w-full md:w-[45%] lg:w-fit font-inter px-8 py-3 rounded-lg flex flex-row justify-between items-center gap-x-20 bg-blue-100"><div class="flex flex-row justify-start items-center gap-x-4"><div class="w-6 h-6 rounded-full overflow-hidden"><svg xmlns="http://www.w3.org/2000/svg" viewBox="85.5 0 342 342"><path fill="#FFF" d="M0 0h513v342H0z"/><path fill="#0052B4" d="M0 0h171v342H0z"/><path fill="#D80